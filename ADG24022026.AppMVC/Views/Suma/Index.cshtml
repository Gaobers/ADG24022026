@{
    ViewData["Title"] = "Suma con JavaScript";
}
<div class="container mt-5">
<h2>Calculadora  </h2>
<hr />
    <div class="row">
        <div class="col-md-4">
            <label>Número 1:</label>
            <input type="number" id="n1" class="form-control" placeholder="Ej: 10">
            
            <label class="mt-2">Número 2:</label>
            <input type="number" id="n2" class="form-control" placeholder="Ej: 20">

            <button type="button" onclick="realizarSuma()" class="btn btn-success mt-3 w-100">
                Calcular Suma
            </button>
        </div>
        <div class="col-md-6 mt-4 mt-md-0">
            <div id="cajaResultado" class="alert alert-info d-none">
                <strong>Resultado: </strong> <span id="resultadoTexto"></span>
            </div>
        </div>
    </div>
</div>

<script>

function realizarSuma() {
// 1. Obtener los valores de los inputs
const num1 = parseFloat(document.getElementById('n1').value);
const num2 = parseFloat(document.getElementById('n2').value);
const display = document.getElementById('cajaResultado');
const span = document.getElementById('resultadoTexto');

// 2. Validar que sean números válidos
if (isNaN(num1) || isNaN(num2)) {
alert("Por favor, ingresa ambos números.");
return;
}

// 3. Hacer la operación
const suma = num1 + num2;

     // 4. Mostrar el resultado quitando la clase 'd-none' (oculto)
            span.innerText = suma;
            display.classList.remove('d-none');
        }
</script>