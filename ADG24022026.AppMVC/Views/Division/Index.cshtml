<style>
    .calculadora-container {
        max-width: 400px;
        margin: 40px auto;
        padding: 25px;
        border: 1px solid #ddd;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        font-family: Arial, sans-serif;
        background-color: #fafafa;
    }

        .calculadora-container h1 {
            text-align: center;
            margin-bottom: 20px;
            font-size: 22px;
            font-weight: 500;
        }

    .form-group {
        margin-bottom: 15px;
    }

    label {
        display: block;
        margin-bottom: 5px;
        font-size: 14px;
        color: #555;
    }

    input {
        width: 100%;
        padding: 8px;
        border-radius: 5px;
        border: 1px solid #ccc;
        font-size: 14px;
    }

        input:focus {
            outline: none;
            border-color: #888;
        }

    button {
        width: 100%;
        padding: 10px;
        border: none;
        border-radius: 5px;
        background-color: #444;
        color: white;
        font-size: 14px;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        button:hover {
            background-color: #333;
        }

    .resultado-box {
        margin-top: 20px;
        padding: 12px;
        background-color: #f0f0f0;
        border-radius: 6px;
        text-align: right;
        font-size: 18px;
        font-weight: bold;
        color: #333;
        min-height: 30px;
    }
</style>

<div class="calculadora-container">
    <h1>División</h1>

    <form asp-action="Index" method="POST">
        <div class="form-group">
            <label for="numero1">Número 1:</label>
            <input type="number" name="numero1" id="numero1" required>
        </div>

        <div class="form-group">
            <label for="numero2">Número 2:</label>
            <input type="number" name="numero2" id="numero2" required>
        </div>

        <button type="submit">Dividir</button>
    </form>
    <div class="resultado-box">
        @ViewBag.Resultado
    </div>
</div>